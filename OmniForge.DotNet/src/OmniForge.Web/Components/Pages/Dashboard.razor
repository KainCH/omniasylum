@page "/dashboard"
@page "/manage/{StreamerId}/dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using System.Security.Claims
@using OmniForge.Core.Entities
@using OmniForge.Web.Components.Modals
@using OmniForge.Web.Components.Shared
@using System.Threading
@using OmniForge.Core.Interfaces
@attribute [Authorize]
@inject ICounterRepository CounterRepository
@inject IUserRepository UserRepository
@inject NavigationManager NavigationManager
@inject IStreamMonitorService StreamMonitorService
@inject IOverlayNotifier OverlayNotifier
@inject IDashboardFeedService DashboardFeedService
@inject ITwitchApiService TwitchApiService
@implements IDisposable

<PageTitle>Channel Control System</PageTitle>

<div class="dashboard-layout">
  <div class="dashboard-main-col">
    <div class="stream-counter-container">
      <span class="monitor-status-badge @(isLive ? "status-live" : isMonitoring ? "status-active" : "status-inactive")"
            title="@(isLive ? "Stream Live" : isMonitoring ? "Monitor Active" : "Monitor Inactive")">
        <i class="bi bi-circle-fill"></i>
      </span>
      <h1>Channel Control System</h1>

      <AuthorizeView>
        <Authorized>
          @if (!hasAccess)
          {
            <div class="alert alert-danger mt-3" role="alert">
              @(accessDeniedMessage ?? "Access denied.")
            </div>
          }
          else
            @if (counter == null)
            {
              <p><em>Loading counters...</em></p>
            }
            else
            {
              <div class="current-game mb-3">
                <span class="current-game-label">Current Game:</span>
                <span class="current-game-name">@(string.IsNullOrEmpty(counter.LastCategoryName) ? "Not set" :
                                                                      counter.LastCategoryName)</span>
                </div>



                if (!string.IsNullOrEmpty(errorMessage))
                {
                  <div class="alert alert-danger mt-3" role="alert">
                    @errorMessage
                  </div>
                }
                else if (!string.IsNullOrEmpty(overlaySaveError))
                {
                  <div class="alert alert-warning mt-3" role="alert">
                    @overlaySaveError
                  </div>
                }

                <div class="controls-section">
                  <button class="btn-custom @(isMonitoring ? "btn-danger" : "btn-success")" @onclick="ToggleMonitoring">
                    <i class="bi @(isMonitoring ? "bi-stop-circle-fill" : "bi-play-circle-fill") me-1"></i>
                    <span>@(isMonitoring ? "Stop Monitor" : "Start Monitor")</span>
                  </button>

                  <button class="btn-custom btn-settings" @onclick="() => showOverlaySettings = true">
                    <i class="bi bi-gear-fill"></i> Settings
                  </button>
                  <button class="btn-custom btn-settings" @onclick="() => showTimerSettings = true" title="Timer Settings">
                    <i class="bi bi-stopwatch"></i> Timer
                  </button>
                  <button class="btn-custom btn-settings" @onclick="() => showShoutoutSettings = true"
                          title="Auto-Shoutout Settings">
                    <i class="bi bi-robot"></i> Bot
                  </button>
                </div>

                @if (isMonitoring)
                {
                  <div class="row g-3 mt-3">
                    @if (isLive)
                    {
                      <div class="col-md-6">
                        <div class="card h-100">
                          <div class="card-header d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><i class="bi bi-rocket-takeoff me-1"></i> Raid Suggestions</h6>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="FetchRaidTargetsAsync"
                                    disabled="@isLoadingRaidTargets" title="Refresh">
                              @if (isLoadingRaidTargets)
                              {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                              }
                              else
                              {
                                <i class="bi bi-arrow-clockwise"></i>
                              }
                            </button>
                          </div>
                          <div class="card-body p-2" style="max-height:300px;overflow-y:auto;">
                            @if (isLoadingRaidTargets && raidTargets.Count == 0)
                            {
                              <p class="text-muted small text-center mt-3"><span class="spinner-border spinner-border-sm"></span>
                                Loading...</p>
                              }
                        else if (raidTargets.Count == 0)
                              {
                                <p class="text-muted small text-center mt-3">No raid targets found.</p>
                              }
                              else
                              {
                                @foreach (var target in raidTargets)
                                {
                                  <div class="d-flex justify-content-between align-items-center border-bottom py-1 px-1">
                                    <div class="small">
                                      <strong>@target.BroadcasterName</strong><br />
                                      <span class="text-muted">@target.ViewerCount viewers</span>
                                      @if (!string.IsNullOrWhiteSpace(target.GameName))
                                      {
                                        <span class="text-muted"> · @target.GameName</span>
                                      }
                                    </div>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => StartRaidAsync(target.BroadcasterId, target.BroadcasterName)">
                                      Raid →
                                    </button>
                                  </div>
                                }
                              }
                            </div>
                            @if (raidLastRefreshedAt.HasValue)
                            {
                              <div class="card-footer text-muted small">
                                Last refreshed: @raidLastRefreshedAt.Value.ToLocalTime().ToString("HH:mm:ss")
                                @if (!string.IsNullOrEmpty(raidSource))
                                {
                                  <span> · @raidSource</span>
                                }
                              </div>
                            }
                          </div>
                        </div>
                      }

                      <div class="@(isLive ? "col-md-6" : "col-md-12")">
                        <div class="card h-100">
                          <div class="card-header">
                            <h6 class="mb-0"><i class="bi bi-bell me-1"></i> Channel Events</h6>
                          </div>
                          <div class="card-body p-2" style="max-height:300px;overflow-y:auto;">
                            @if (channelEvents.Count == 0)
                            {
                              <p class="text-muted small text-center mt-3">No events yet this session.</p>
                            }
                            else
                            {
                              @foreach (var evt in Enumerable.Reverse(channelEvents))
                              {
                                <div class="small mb-1 border-bottom pb-1">
                                  <span>@evt.Description</span>
                                  <span class="text-muted float-end">@evt.Timestamp.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                              }
                            }
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="mt-3">
                      <button class="btn btn-sm btn-outline-secondary w-100" @onclick="() => showCounters = !showCounters">
                        <i class="bi @(showCounters ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>
                        @(showCounters ? "Hide Counters" : "▸ Counters")
                      </button>
                      @if (showCounters)
                      {
                        <div class="counter-list mt-2">
                          @if (overlaySettings?.Counters?.Deaths != false)
                          {
                            <div class="counter-item" data-counter="deaths">
                              <span class="counter-name">Deaths</span>
                              <span class="counter-value">@counter.Deaths</span>
                            </div>
                          }
                          @if (overlaySettings?.Counters?.Swears != false)
                          {
                            <div class="counter-item" data-counter="swears">
                              <span class="counter-name">Swears</span>
                              <span class="counter-value">@counter.Swears</span>
                            </div>
                          }
                          @if (overlaySettings?.Counters?.Screams != false)
                          {
                            <div class="counter-item" data-counter="screams">
                              <span class="counter-name">Screams</span>
                              <span class="counter-value">@counter.Screams</span>
                            </div>
                          }
                          @if (overlaySettings?.Counters?.Bits == true)
                          {
                            <div class="counter-item" data-counter="bits">
                              <span class="counter-name">Bits</span>
                              <span class="counter-value">@counter.Bits</span>
                            </div>
                          }
                          @foreach (var kvp in counter.CustomCounters)
                          {
                            <div class="counter-item" data-counter="@kvp.Key.ToLower()">
                              <span class="counter-name">@kvp.Key</span>
                              <span class="counter-value">@kvp.Value</span>
                            </div>
                          }
                        </div>
                      }
                    </div>
                  }
            else
                  {
                    <div class="counter-list mt-3">
                      @if (overlaySettings?.Counters?.Deaths != false)
                      {
                        <div class="counter-item" data-counter="deaths">
                          <span class="counter-name">Deaths</span>
                          <span class="counter-value">@counter.Deaths</span>
                        </div>
                      }
                      @if (overlaySettings?.Counters?.Swears != false)
                      {
                        <div class="counter-item" data-counter="swears">
                          <span class="counter-name">Swears</span>
                          <span class="counter-value">@counter.Swears</span>
                        </div>
                      }
                      @if (overlaySettings?.Counters?.Screams != false)
                      {
                        <div class="counter-item" data-counter="screams">
                          <span class="counter-name">Screams</span>
                          <span class="counter-value">@counter.Screams</span>
                        </div>
                      }
                      @if (overlaySettings?.Counters?.Bits == true)
                      {
                        <div class="counter-item" data-counter="bits">
                          <span class="counter-name">Bits</span>
                          <span class="counter-value">@counter.Bits</span>
                        </div>
                      }
                      @foreach (var kvp in counter.CustomCounters)
                      {
                        <div class="counter-item" data-counter="@kvp.Key.ToLower()">
                          <span class="counter-name">@kvp.Key</span>
                          <span class="counter-value">@kvp.Value</span>
                        </div>
                      }
                    </div>
                  }

                  <div class="card mt-4 mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center"
                         @onclick="() => showSetup = !showSetup" style="cursor: pointer;">
                      <h5 class="mb-0"><i class="bi bi-rocket-takeoff"></i> Getting Started</h5>
                      <i class="bi @(showSetup ? "bi-chevron-up" : "bi-chevron-down")"></i>
                    </div>
                    @if (showSetup)
                    {
                      <div class="card-body">
                        <div class="list-group list-group-flush">
                          <div class="list-group-item">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Set up your overlay</strong> &mdash; Copy the Overlay URL below and add it as
                            a Browser Source in OBS/Streamlabs (width: 1920, height: 1080).
                          </div>
                          <div class="list-group-item">
                            <i class="bi bi-gear me-2"></i>
                            <strong>Customize settings</strong> &mdash; Click <em>Settings</em> above to choose
                            which counters to show, colors, positioning, and alert sounds.
                          </div>
                          <div class="list-group-item">
                            <i class="bi bi-broadcast me-2"></i>
                            <strong>Start monitoring</strong> &mdash; Click <em>Start Monitor</em> to connect to
                            Twitch and begin tracking events (follows, subs, bits, etc).
                          </div>
                          @if (currentUserEntity?.Features.DiscordNotifications == true)
                          {
                            <div class="list-group-item">
                              <i class="bi bi-discord me-2"></i>
                              <strong>Connect Discord</strong> &mdash;
                              <a href="/settings/discord">Configure Discord</a> to get notifications
                              in your server.
                            </div>
                          }
                          @if (currentUserEntity?.Features.StreamAlerts == true)
                          {
                            <div class="list-group-item">
                              <i class="bi bi-bell me-2"></i>
                              <strong>Configure alerts</strong> &mdash;
                              <a href="/alerts">Set up alert images and sounds</a> for follows,
                              subs, and other events.
                            </div>
                          }
                          @if (currentUserEntity?.Features.OverlayV2 == true)
                          {
                            <div class="list-group-item">
                              <i class="bi bi-stars text-warning me-2"></i>
                              <strong>V2 Overlay</strong> &mdash; You have access to the premium overlay
                              with SSE transport and advanced features. Use the V2 URL below.
                            </div>
                          }
                          else
                          {
                            <div class="list-group-item">
                              <i class="bi bi-lock me-2"></i>
                              <strong>V2 Overlay (Pro)</strong> &mdash; Upgrade to Pro for the advanced
                              overlay with real-time SSE transport and enhanced visuals.
                            </div>
                          }
                          @if (currentUserEntity?.Features.SceneSync == true)
                          {
                            <div class="list-group-item">
                              <i class="bi bi-display me-2"></i>
                              <strong>Scene Sync Agent</strong> &mdash;
                              <a href="/api/sync/agent/download" target="_blank">Download the agent</a>
                              to sync OBS scenes with automated actions.
                            </div>
                          }
                        </div>
                      </div>
                    }
                  </div>

                  <div class="mt-4 text-center">
                    <p>
                      <strong>Twitch User ID:</strong> @TwitchUserId <br />
                      <strong>Overlay URL (v1):</strong> <a href="@OverlayUrl" target="_blank">@OverlayUrl</a><br />
                      <strong>Preview URL (v1):</strong> <a href="@OverlayPreviewUrl" target="_blank">@OverlayPreviewUrl</a>

                      <br />
                      @if (currentUserEntity?.Features.OverlayV2 == true)
                      {
                        <strong>Overlay URL (v2):</strong>
                        <a href="@OverlayV2Url" target="_blank">@OverlayV2Url</a>
                        <br />
                        <strong>Preview URL (v2):</strong>
                        <a href="@OverlayV2PreviewUrl" target="_blank">@OverlayV2PreviewUrl</a>
                      }
                      else
                      {
                        <strong>Overlay V2:</strong>
                        <i class="bi bi-lock-fill text-muted"></i>
                        <a href="/upgrade" class="text-warning">Upgrade to Pro</a>
                        <span class="text-muted">&mdash; Advanced overlay with real-time SSE transport</span>
                      }
                    </p>

                    @if (overlaySettings != null)
                    {
                      <div class="d-flex justify-content-center align-items-center gap-2 mt-2">
                        <div class="form-check form-switch">
                          <input id="offlinePreviewToggle" class="form-check-input" type="checkbox"
                                 checked="@overlaySettings.OfflinePreview" @onchange="OnOfflinePreviewChanged" />
                          <label class="form-check-label" for="offlinePreviewToggle">Offline Preview (force visible when
                            offline)</label>
                          </div>
                          @if (savingOfflinePreview)
                          {
                            <span class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></span>
                          }
                        </div>
                      }
                    </div>

                    @if (currentUserEntity?.Features.SceneSync == true)
                    {
                      <div class="mt-2">
                        <strong>Sync Agent:</strong>
                        <a href="/api/sync/agent/download" target="_blank">Download OmniForge Sync Agent</a>
                      </div>
                    }

                    <AgentStatusBadge UserId="@TwitchUserId" />

                    <OverlaySettingsModal @bind-Show="showOverlaySettings" UserId="@TwitchUserId" OnSaved="OnSettingsSaved" />
                    <TimerSettingsModal @bind-Show="showTimerSettings" UserId="@TwitchUserId" OnSaved="OnSettingsSaved" />
                    <AutoShoutoutSettingsModal @bind-Show="showShoutoutSettings" UserId="@TwitchUserId" />
                  }
                </Authorized>
              </AuthorizeView>
            </div>
        </div>
        @if (isMonitoring)
        {
          <div class="dashboard-chat-col">
            <div class="card chat-panel-card">
              <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-chat-dots me-1"></i> Live Chat</h6>
              </div>
              <div class="card-body p-2" id="chat-feed">
                @if (chatMessages.Count == 0)
                {
                  <p class="text-muted small text-center mt-3">Waiting for chat messages...</p>
                }
                else
                {
                  @foreach (var msg in chatMessages)
                  {
                    <div class="small mb-1">
                      <span class="fw-semibold" style="color:@(msg.ColorHex ?? "#9b59b6")">@msg.DisplayName</span>
                      <span class="text-body">: @msg.Message</span>
                    </div>
                  }
                }
              </div>
            </div>
          </div>
        }
      </div>

@code {
  [CascadingParameter]
  private Task<AuthenticationState>? authenticationStateTask { get; set; }

  [Parameter]
  public string? StreamerId { get; set; }

  private OmniForge.Core.Entities.Counter? counter;
  private OmniForge.Core.Entities.OverlaySettings? overlaySettings;
  private string? TwitchUserId;
  private string? OverlayUrl;
  private string? OverlayPreviewUrl;
  private string? OverlayV2Url;
  private string? OverlayV2PreviewUrl;
  private bool showSetup = false;
  private bool savingOfflinePreview = false;
  private bool showOverlaySettings = false;
  private bool showTimerSettings = false;
  private bool showShoutoutSettings = false;
  private bool isMonitoring = false;
  private bool isLive = false;
  private bool showCounters = false;
  private bool isLoadingRaidTargets = false;
  private List<OmniForge.Core.Interfaces.DashboardChatMessage> chatMessages = new(50);
  private List<OmniForge.Core.Interfaces.DashboardEvent> channelEvents = new(20);
  private List<OmniForge.Core.Interfaces.RaidTargetDto> raidTargets = new();
  private string? raidSource;
  private DateTimeOffset? raidLastRefreshedAt;
  private IDisposable? _feedSubscription;
  private Timer? _raidRefreshTimer;
  private OmniForge.Core.Interfaces.StreamMonitorStatus? monitorStatus;
  private Timer? _refreshTimer;
  private string? errorMessage;
  private string? overlaySaveError;
  private bool hasAccess = true;
  private string? accessDeniedMessage;
  private OmniForge.Core.Entities.User? currentUserEntity;

  protected override async Task OnInitializedAsync()
  {
    if (authenticationStateTask != null)
    {
      var authState = await authenticationStateTask;
      var user = authState.User;

      if (user.Identity?.IsAuthenticated == true)
      {
        var actingUserId = user.FindFirst("userId")?.Value
          ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
          ?? user.FindFirst("sub")?.Value;

        if (string.IsNullOrWhiteSpace(actingUserId))
        {
          hasAccess = false;
          accessDeniedMessage = "Unable to determine user identity. Please re-login.";
          return;
        }

        var targetUserId = string.IsNullOrWhiteSpace(StreamerId) ? actingUserId : StreamerId;

        if (!string.Equals(targetUserId, actingUserId, StringComparison.Ordinal))
        {
          var actingUser = await UserRepository.GetUserAsync(actingUserId);
          hasAccess = actingUser != null &&
            (string.Equals(actingUser.Role, "admin", StringComparison.OrdinalIgnoreCase) ||
             (actingUser.ManagedStreamers?.Contains(targetUserId) == true));

          if (!hasAccess)
          {
            accessDeniedMessage = "You do not have permission to manage this streamer.";
            return;
          }
        }

        TwitchUserId = targetUserId;

        if (!string.IsNullOrEmpty(TwitchUserId))
        {
          counter = await CounterRepository.GetCountersAsync(TwitchUserId);

          // Load user settings to determine which counters to show
          var userEntity = await UserRepository.GetUserAsync(TwitchUserId);
          currentUserEntity = userEntity;
          overlaySettings = userEntity?.OverlaySettings ?? new OmniForge.Core.Entities.OverlaySettings();

          // Use the static HTML overlay instead of the Blazor page
          OverlayUrl = NavigationManager.ToAbsoluteUri($"/overlay.html?userId={TwitchUserId}").ToString();
          OverlayPreviewUrl = $"{OverlayUrl}&preview=true";

          // v2 overlay (Blazor/Razor)
          OverlayV2Url = NavigationManager.ToAbsoluteUri($"/overlay/v2/{TwitchUserId}").ToString();
          OverlayV2PreviewUrl = $"{OverlayV2Url}?preview=true";

          // Initial check
          RefreshStatus();

          // Subscribe to dashboard feed
          _feedSubscription = DashboardFeedService.Subscribe(
            TwitchUserId,
            OnChatMessage,
            OnChannelEvent,
            OnLiveStatusChanged);

          // Check current live status
          isLive = DashboardFeedService.GetLiveStatus(TwitchUserId);
          if (isLive)
          {
            await FetchRaidTargetsAsync();
            StartRaidRefreshTimer();
          }

          // Start timer to refresh status every 5 seconds
          _refreshTimer = new Timer(_ =>
          {
            InvokeAsync(() =>
  {
    // Only refresh if no modals are open to prevent interfering with user edits
    if (!IsAnyModalOpen())
    {
      RefreshStatus();
      StateHasChanged();
    }
  });
          }, null, 5000, 5000);
        }
      }
    }
  }

  private void RefreshStatus()
  {
    if (!string.IsNullOrEmpty(TwitchUserId))
    {
      isMonitoring = StreamMonitorService.IsUserSubscribed(TwitchUserId);
      monitorStatus = StreamMonitorService.GetUserConnectionStatus(TwitchUserId);
    }
  }

  private bool IsAnyModalOpen()
  {
    return showOverlaySettings || showTimerSettings || showShoutoutSettings;
  }

  public void Dispose()
  {
    _refreshTimer?.Dispose();
    _feedSubscription?.Dispose();
    _raidRefreshTimer?.Dispose();
  }

  private void OnChatMessage(OmniForge.Core.Interfaces.DashboardChatMessage msg)
  {
    if (!string.Equals(msg.UserId, TwitchUserId, StringComparison.Ordinal)) return;
    if (chatMessages.Count >= 50) chatMessages.RemoveAt(0);
    chatMessages.Add(msg);
    InvokeAsync(StateHasChanged);
  }

  private void OnChannelEvent(OmniForge.Core.Interfaces.DashboardEvent evt)
  {
    if (channelEvents.Count >= 20) channelEvents.RemoveAt(0);
    channelEvents.Add(evt);
    InvokeAsync(StateHasChanged);
  }

  private void OnLiveStatusChanged(bool live)
  {
    isLive = live;
    if (live)
    {
      _ = InvokeAsync(async () =>
      {
        await FetchRaidTargetsAsync();
        StartRaidRefreshTimer();
      });
    }
    else
    {
      _raidRefreshTimer?.Dispose();
      _raidRefreshTimer = null;
      InvokeAsync(StateHasChanged);
    }
  }

  private void StartRaidRefreshTimer()
  {
    _raidRefreshTimer?.Dispose();
    _raidRefreshTimer = new Timer(async _ =>
    {
      await FetchRaidTargetsAsync();
      await InvokeAsync(StateHasChanged);
    }, null, 30_000, 30_000);
  }

  private async Task FetchRaidTargetsAsync()
  {
    if (string.IsNullOrEmpty(TwitchUserId)) return;
    isLoadingRaidTargets = true;
    await InvokeAsync(StateHasChanged);

    try
    {
      var targets = await TwitchApiService.GetFollowedLiveStreamsAsync(TwitchUserId, 5);
      raidSource = "following";

      if (targets.Count == 0)
      {
        var channelCategory = await TwitchApiService.GetChannelCategoryAsync(TwitchUserId);
        if (channelCategory != null && !string.IsNullOrWhiteSpace(channelCategory.GameId))
        {
          targets = await TwitchApiService.GetStreamsByGameIdAsync(TwitchUserId, channelCategory.GameId, 5);
          raidSource = $"same game ({channelCategory.GameName})";
        }
      }

      raidTargets = new List<OmniForge.Core.Interfaces.RaidTargetDto>(targets);
      raidLastRefreshedAt = DateTimeOffset.UtcNow;
    }
    catch (Exception ex)
    {
      _ = ex; // log if needed
    }
    finally
    {
      isLoadingRaidTargets = false;
      await InvokeAsync(StateHasChanged);
    }
  }

  private async Task StartRaidAsync(string targetBroadcasterId, string targetName)
  {
    if (string.IsNullOrEmpty(TwitchUserId)) return;
    var success = await TwitchApiService.StartRaidAsync(TwitchUserId, targetBroadcasterId);
    errorMessage = success ? null : $"❌ Failed to start raid to {targetName}.";
    StateHasChanged();
  }

  private async Task ToggleMonitoring()
  {
    if (string.IsNullOrEmpty(TwitchUserId)) return;
    errorMessage = null;

    if (isMonitoring)
    {
      await StreamMonitorService.UnsubscribeFromUserAsync(TwitchUserId);
      isMonitoring = false;
    }
    else
    {
      var result = await StreamMonitorService.SubscribeToUserAsync(TwitchUserId);
      if (result == OmniForge.Core.Interfaces.SubscriptionResult.Success)
      {
        isMonitoring = true;
      }
      else if (result == OmniForge.Core.Interfaces.SubscriptionResult.Unauthorized)
      {
        errorMessage = "Authorization failed. You may need to re-login to grant new permissions.";
        // Optional: Redirect to login to force re-auth
        NavigationManager.NavigateTo("/auth/twitch?force_verify=true", true);
      }
      else
      {
        errorMessage = "Failed to start monitoring. Check logs for details.";
      }
    }

    monitorStatus = StreamMonitorService.GetUserConnectionStatus(TwitchUserId);
  }

  private async Task OnSettingsSaved()
  {
    // Reload user settings to update which counters are shown
    if (!string.IsNullOrEmpty(TwitchUserId))
    {
      var userEntity = await UserRepository.GetUserAsync(TwitchUserId);
      overlaySettings = userEntity?.OverlaySettings ?? new OmniForge.Core.Entities.OverlaySettings();
      StateHasChanged();
    }
  }

  private async Task OnOfflinePreviewChanged(ChangeEventArgs e)
  {
    if (overlaySettings == null || string.IsNullOrEmpty(TwitchUserId)) return;

    bool newValue = false;
    if (e.Value is bool b)
    {
      newValue = b;
    }
    else if (e.Value != null)
    {
      newValue = e.Value.ToString()?.Equals("true", StringComparison.OrdinalIgnoreCase) == true;
    }

    overlaySettings.OfflinePreview = newValue;
    savingOfflinePreview = true;
    overlaySaveError = null;

    try
    {
      var userEntity = await UserRepository.GetUserAsync(TwitchUserId);
      if (userEntity != null)
      {
        userEntity.OverlaySettings = overlaySettings;
        await UserRepository.SaveUserAsync(userEntity);
      }
    }
    catch (Exception ex)
    {
      overlaySaveError = $"Error saving offline preview: {ex.Message}";
    }
    finally
    {
      savingOfflinePreview = false;
      StateHasChanged();
    }
  }

}
